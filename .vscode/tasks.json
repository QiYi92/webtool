{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev:frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "kind": "file",
            "file": 1,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting|ready - started server on|▲ Next\\.js",
          "endsPattern": "Ready in|ready - started server on"
        }
      }
    },
    {
      "label": "dev:backend",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "source .venv/bin/activate && uvicorn app.main:app --reload --host 0.0.0.0 --port 8888"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "kind": "file",
            "file": 1,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Uvicorn running on",
          "endsPattern": "Uvicorn running on"
        }
      }
    },
    {
      "label": "dev",
      "dependsOrder": "parallel",
      "dependsOn": [
        "dev:frontend",
        "dev:backend"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
